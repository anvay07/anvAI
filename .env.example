# AnVAI — copy this file to .env and fill in real values
# NEVER commit .env to git

# AI Native API (Anthropic-compatible proxy) — used for crisis-detection classifier
AINATIVE_API_KEY=sk_YOUR_KEY_HERE
AINATIVE_BASE_URL=https://api.ainative.studio

# TensorX (OpenAI-compatible router) — used for the main chat responses
TENSORX_API_KEY=YOUR_TENSORX_KEY_HERE
TENSORX_BASE_URL=https://api.tensorx.ai/v1

# Postgres — enables Google sign-in + persisted per-account chat history.
# Leave unset to run anonymous-only (no accounts, no server-side history).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google OAuth Client ID (Google Identity Services) — required together with
# DATABASE_URL to enable sign-in. Create one at console.cloud.google.com
# (APIs & Services > Credentials > OAuth client ID > Web application).
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Server
PORT=3000
NODE_ENV=production

# CORS — comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=https://anvai.app

# Crisis region for helpline routing
CRISIS_REGION=US
